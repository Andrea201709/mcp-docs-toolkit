# mcp-docs-toolkit environment configuration
# Copy this file to .env and fill in the values for your backend.
# Do not commit real values to version control.

# --- Keycloak backend ---
MCP_DOCS_KEYCLOAK_URL=<your-keycloak-url>
MCP_DOCS_KEYCLOAK_REALM=<your-realm>
MCP_DOCS_CLIENT_ID=<your-client-id>
MCP_DOCS_CLIENT_SECRET=<your-client-secret>
MCP_DOCS_USERNAME=<your-username>
MCP_DOCS_PASSWORD=<your-password>
MCP_DOCS_API_URL=<your-document-api-url>

# --- Notion backend ---
MCP_DOCS_NOTION_TOKEN=<your-notion-integration-token>
# MCP_DOCS_NOTION_API_URL=https://api.notion.com
# MCP_DOCS_NOTION_VERSION=2022-06-28

# --- Confluence backend ---
MCP_DOCS_CONFLUENCE_URL=<your-confluence-url>
MCP_DOCS_CONFLUENCE_EMAIL=<your-email>
MCP_DOCS_CONFLUENCE_API_TOKEN=<your-api-token>

# --- Google Drive backend ---
MCP_DOCS_GOOGLE_ACCESS_TOKEN=<your-oauth2-access-token>

# --- Shared options ---
MCP_DOCS_TIMEOUT_SECONDS=30
MCP_DOCS_OUTPUT_DIR=downloads
